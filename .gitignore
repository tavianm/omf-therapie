# Auto-generated build-env snapshot for the cron runtime. Regenerated by the
# prebuild/predev/pretest/pretypecheck hooks AND netlify.toml [build] command.
# Committing the cron-side stub (introduced in #111) risked a stale
# "development"/"dev" value leaking into a build that skipped the hook (wrong
# Sentry environment tag). Now ignored so the generator is the single source.
netlify/functions/_lib/build-env.ts

