# =============================================================================
# Variables d'environnement — Développement local
# Copier ce fichier en .env et adapter si nécessaire
# NE JAMAIS committer .env — voir .gitignore
# =============================================================================

# ── PostgreSQL local (Docker) ─────────────────────────────────────────────────
# Remplace Supabase en local — pointe vers le proxy Nginx → PostgREST (docker-compose)
# Stack complète requise : docker compose up -d (postgres + postgrest + supabase-rest + mailpit)
SUPABASE_URL=http://localhost:3001
# SUPABASE_DATABASE_URL est la variable lue par src/lib/supabase.ts
SUPABASE_DATABASE_URL=http://localhost:3001
# JWT HS256 signé avec PGRST_JWT_SECRET (docker-compose.yml)
# Généré via : node -e "const s='local-jwt-secret-must-be-at-least-32-characters';const h=Buffer.from(JSON.stringify({alg:'HS256',typ:'JWT'})).toString('base64url');const p=Buffer.from(JSON.stringify({role:'postgres',iat:1000000000,exp:9999999999})).toString('base64url');const c=require('crypto');const sig=c.createHmac('sha256',s).update(h+'.'+p).digest('base64url');console.log(h+'.'+p+'.'+sig)"
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoicG9zdGdyZXMiLCJpYXQiOjEwMDAwMDAwMDAsImV4cCI6OTk5OTk5OTk5OX0.3VmVC59oRVl6o2gQM0YimqcawheIUsbajlHxyJ8vtuc
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoicG9zdGdyZXMiLCJpYXQiOjEwMDAwMDAwMDAsImV4cCI6OTk5OTk5OTk5OX0.3VmVC59oRVl6o2gQM0YimqcawheIUsbajlHxyJ8vtuc

# ── BetterAuth ────────────────────────────────────────────────────────────────
# Connexion directe au PostgreSQL Docker
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/omf_therapie
# Générer avec : openssl rand -base64 32
BETTER_AUTH_SECRET=dev-secret-change-me-in-production-32c
BETTER_AUTH_URL=http://localhost:4321

# ── Email admin ───────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@localhost.dev
ADMIN_PASSWORD=DevPassword!LocalOnly123
ADMIN_NAME=Oriane Montabonnet

# ── SMTP local (Mailpit) ──────────────────────────────────────────────────────
# Active le fallback SMTP dans src/lib/resend.ts (bypass Resend SDK)
# Interface web Mailpit : http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
RESEND_FROM_EMAIL=OMF Thérapie <contact@omf-therapie.fr>
# RESEND_API_KEY non requis en local quand SMTP_HOST est défini

# ── Stripe (clés de TEST) ─────────────────────────────────────────────────────
# Utiliser les clés sk_test_ / pk_test_ depuis dashboard.stripe.com/test
STRIPE_SECRET_KEY=sk_test_REMPLACER_PAR_VOTRE_CLE_TEST
STRIPE_PUBLISHABLE_KEY=pk_test_REMPLACER_PAR_VOTRE_CLE_TEST
# Généré par : stripe listen --forward-to localhost:4321/api/stripe-webhook
STRIPE_WEBHOOK_SECRET=whsec_GENERE_PAR_STRIPE_CLI
STRIPE_SUCCESS_URL=http://localhost:4321/rdv/merci

# ── Google Calendar (mode mock) ───────────────────────────────────────────────
# Active les créneaux factices dans src/lib/google-calendar.ts
# Aucun appel réseau vers l'API Google n'est effectué
GOOGLE_CALENDAR_MOCK=true
# Variables ci-dessous non utilisées si GOOGLE_CALENDAR_MOCK=true
GOOGLE_SERVICE_ACCOUNT_EMAIL=mock@example.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nmock\n-----END PRIVATE KEY-----"
GOOGLE_CALENDAR_ID=primary
# Optionnel: test OAuth utilisateur (3-legged) local avec GOOGLE_CALENDAR_MOCK=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_OAUTH_REDIRECT_URI=https://developers.google.com/oauthplayground

# ── Avis (optionnel) ──────────────────────────────────────────────────────────
GOOGLE_BUSINESS_URL=https://g.page/r/votre-fiche
PAGES_JAUNES_URL=https://www.pagesjaunes.fr/votre-fiche
PSYCHOLOGUE_NET_URL=https://www.psychologue.net/votre-profil
