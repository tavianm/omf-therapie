---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  h1: string;
  intro: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, canonical, h1, intro, jsonLd } = Astro.props;
---

<Layout {title} {description} {canonical} {jsonLd} ogType="website">
  <slot name="navbar" />

  <main id="main-content" tabindex="-1">
    <!-- Hero section for service page -->
    <section class="bg-sage-50 py-16 px-4">
      <div class="max-w-4xl mx-auto">
        <nav class="mb-6 text-sm text-sage-500" aria-label="Fil d'Ariane">
          <ol class="flex items-center gap-2 flex-wrap" role="list">
            <li role="listitem"><a href="/" class="hover:text-mint-600 transition-colors">Accueil</a></li>
            <li role="listitem" aria-hidden="true">›</li>
            <li role="listitem"><a href="/#services" class="hover:text-mint-600 transition-colors">Services</a></li>
            <li role="listitem" aria-hidden="true">›</li>
            <li role="listitem" aria-current="page" class="text-sage-700 font-medium">{h1}</li>
          </ol>
        </nav>
        <h1 class="font-serif text-3xl md:text-4xl lg:text-5xl text-sage-800 mb-6">{h1}</h1>
        <p class="text-lg text-sage-600 leading-relaxed max-w-2xl">{intro}</p>
      </div>
    </section>

    <!-- Main content slot -->
    <slot />

    <!-- FAQ slot -->
    <slot name="faq" />

    <!-- CTA section -->
    <section class="bg-mint-50 py-12 px-4">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="font-serif text-2xl text-sage-800 mb-4">Prêt(e) à commencer ?</h2>
        <p class="text-sage-600 mb-6">Contactez Oriane Montabonnet pour un premier échange confidentiel.</p>
        <a
          href="/contact"
          class="inline-block bg-mint-600 text-white px-8 py-3 rounded-lg hover:bg-mint-700 transition-colors font-medium"
          aria-label="Prendre rendez-vous avec Oriane Montabonnet"
        >
          Prendre rendez-vous
        </a>
      </div>
    </section>
  </main>

  <slot name="footer" />
</Layout>
