---
import {
  BUSINESS_HOURS,
  COMPANY_DESCRIPTION,
  COMPANY_NAME,
  CONTACT_INFO,
  SOCIAL_LINKS,
} from "../../config/global.config";
import { QUICK_LINKS } from "../../config/footer.config";

const currentYear = new Date().getFullYear();
const mapsUrl = `https://www.google.com/maps/search/${encodeURIComponent(COMPANY_NAME + " " + CONTACT_INFO.address)}`;
---

<footer
  class="bg-sage-800 text-sage-100"
  role="contentinfo"
  aria-label="Pied de page"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-4 pt-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">

      <!-- Colonne 1 : Marque -->
      <div class="space-y-4" role="group" aria-label="Marque">
        <div class="flex items-center gap-2">
          <!-- Icône feuille (lucide leaf) -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6 text-mint-400"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-label="leaf"
          >
            <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/>
            <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/>
          </svg>
          <span class="text-lg font-serif font-medium transition-colors">
            {COMPANY_NAME}
          </span>
        </div>
        <p class="text-sage-300 text-sm">{COMPANY_DESCRIPTION}</p>
        <ul
          class="flex items-center gap-4"
          role="list"
          aria-label="Réseaux sociaux"
        >
          {SOCIAL_LINKS.map((link) => (
            <li role="listitem">
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-2 text-sage-300 hover:text-mint-400 hover:underline transition-colors"
                aria-label={link.ariaLabel}
              >
                <!-- Icône Instagram inline SVG -->
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-5 w-5"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                  <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
                </svg>
                <span>{link.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Colonne 2 : Contact -->
      <div role="group" aria-label="Contact">
        <h2 class="text-lg font-medium mb-4 text-sage-100">Contact</h2>
        <ul class="space-y-3" role="list" aria-label="Informations de contact">
          <li role="listitem">
            <a
              href={`tel:${CONTACT_INFO.phoneE164}`}
              class="flex items-center gap-2 text-sage-300 hover:text-mint-400 hover:underline transition-colors"
              aria-label={`Appeler le ${CONTACT_INFO.phone}`}
            >
              <!-- Icône téléphone -->
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="min-h-5 min-w-5 h-5 w-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.88a16 16 0 0 0 6.06 6.06l1.65-1.65a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
              <span>{CONTACT_INFO.phone}</span>
            </a>
          </li>
          <li role="listitem">
            <a
              href={`mailto:${CONTACT_INFO.email}`}
              class="flex items-center gap-2 text-sage-300 hover:text-mint-400 hover:underline transition-colors"
              aria-label={`Envoyer un email à ${CONTACT_INFO.email}`}
            >
              <!-- Icône email -->
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="min-h-5 min-w-5 h-5 w-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect width="20" height="16" x="2" y="4" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
              <span>{CONTACT_INFO.email}</span>
            </a>
          </li>
          <li role="listitem">
            <a
              href={mapsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-sage-300 hover:text-mint-400 hover:underline transition-colors"
              aria-label={`Ouvrir la carte à ${COMPANY_NAME} ${CONTACT_INFO.address}`}
            >
              <!-- Icône épingle carte -->
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="min-h-5 min-w-5 h-5 w-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              <span>{CONTACT_INFO.address}</span>
            </a>
          </li>
        </ul>
      </div>

      <!-- Colonne 3 : Liens Rapides -->
      <nav aria-label="Navigation du pied de page">
        <h2 class="text-lg font-medium mb-4 text-sage-100">Liens Rapides</h2>
        <ul class="space-y-3" role="list">
          {QUICK_LINKS.map((link) => (
            <li role="listitem">
              {link.external ? (
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sage-300 hover:text-mint-400 hover:underline transition-colors"
                  aria-label={`${link.name} (s'ouvre dans un nouvel onglet)`}
                >
                  {link.name}
                </a>
              ) : (
                <a
                  href={link.href}
                  class="text-sage-300 hover:text-mint-400 hover:underline transition-colors"
                >
                  {link.name}
                </a>
              )}
            </li>
          ))}
        </ul>
      </nav>

      <!-- Colonne 4 : Horaires -->
      <div role="group" aria-label="Horaires">
        <h2 class="text-lg font-medium mb-4 text-sage-100">Horaires</h2>
        <div class="space-y-3 text-sage-300">
          <div>{BUSINESS_HOURS.days}</div>
          <ul role="list" aria-label="Horaires d'ouverture">
            {BUSINESS_HOURS.hours.map((hour) => (
              <li role="listitem">{hour.start} - {hour.end}</li>
            ))}
          </ul>
        </div>
        <div class="mt-3">
          <a
            href="https://www.psychologue.net/cabinets/montabonnet-oriane?utm_source=448100&utm_medium=widget&utm_campaign=widget-company_stamp"
            target="_blank"
            rel="noopener noreferrer"
          >
            <img
              src="https://www.psychologue.net/stamp.xpng?com=448100&v=10"
              alt="Montabonnet Oriane"
              width="175"
              height="auto"
              loading="lazy"
            />
          </a>
        </div>
      </div>

    </div>

    <!-- Bas de pied de page -->
    <div class="mt-8 pt-4 border-t border-sage-700 text-center text-sage-300 text-sm flex flex-col md:flex-row items-center justify-center gap-2">
      <span>©{currentYear} Oriane Montabonnet. Tous droits réservés.</span>
      <a
        href="/accessibilite"
        class="hover:text-mint-400 hover:underline transition-colors"
        aria-label="Page accessibilité — non conforme"
      >
        Accessibilité : non conforme
      </a>
    </div>
  </div>
</footer>
