---
// CSS bundled by Vite from the npm package (no CDN, no version mismatch)
import 'vanilla-cookieconsent/dist/cookieconsent.css';
---

<script>
  import * as CookieConsent from 'vanilla-cookieconsent';

  type ConsentUpdate = {
    analytics_storage: 'granted' | 'denied';
    ad_storage: 'granted' | 'denied';
    ad_user_data: 'granted' | 'denied';
    ad_personalization: 'granted' | 'denied';
  };

  function updateConsent(update: ConsentUpdate) {
    // window.gtag shim (main thread) forwards to dataLayer → Partytown worker
    if (typeof window.gtag === 'function') {
      window.gtag('consent', 'update', update);
    }
  }

  CookieConsent.run({
    guiOptions: {
      consentModal: {
        layout: 'bar',
        position: 'bottom',
        equalWeightButtons: false,
        flipButtons: false,
      },
      preferencesModal: {
        layout: 'box',
      },
    },
    categories: {
      necessary: {
        enabled: true,
        readOnly: true,
      },
      analytics: {
        enabled: false,
        autoClear: {
          cookies: [{ name: /^(_ga|_gid|_gat)/ }],
        },
      },
    },
    language: {
      default: 'fr',
      translations: {
        fr: {
          consentModal: {
            title: 'Votre vie privée nous importe',
            description:
              'Nous utilisons des cookies analytiques pour améliorer notre site et mieux comprendre nos visiteurs. Votre consentement est nécessaire.',
            acceptAllBtn: 'Accepter',
            acceptNecessaryBtn: 'Refuser',
            showPreferencesBtn: 'Personnaliser',
          },
          preferencesModal: {
            title: 'Préférences des cookies',
            acceptAllBtn: 'Tout accepter',
            acceptNecessaryBtn: 'Tout refuser',
            savePreferencesBtn: 'Sauvegarder',
            closeIconLabel: 'Fermer',
            sections: [
              {
                title: 'Cookies nécessaires',
                description:
                  "Ces cookies sont indispensables au fonctionnement du site et ne peuvent pas être désactivés.",
                linkedCategory: 'necessary',
              },
              {
                title: 'Cookies analytiques',
                description:
                  "Ces cookies nous permettent de mesurer l'audience du site (Google Analytics 4) pour améliorer nos contenus.",
                linkedCategory: 'analytics',
              },
            ],
          },
        },
      },
    },
    onConsent() {
      if (CookieConsent.acceptedCategory('analytics')) {
        updateConsent({
          analytics_storage: 'granted',
          ad_storage: 'granted',
          ad_user_data: 'granted',
          ad_personalization: 'granted',
        });
      }
    },
    onChange() {
      const granted = CookieConsent.acceptedCategory('analytics');
      updateConsent({
        analytics_storage: granted ? 'granted' : 'denied',
        ad_storage: granted ? 'granted' : 'denied',
        ad_user_data: granted ? 'granted' : 'denied',
        ad_personalization: granted ? 'granted' : 'denied',
      });
    },
  });
</script>
