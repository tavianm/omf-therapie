---
/**
 * Page de connexion — espace praticienne
 *
 * SSR uniquement (prerender = false) :
 * - Vérifie la session existante côté serveur
 * - Redirige vers /mes-rdvs si déjà connectée
 *
 * UI :
 * - Formulaire sobre, thème sage/mint
 * - Soumission via fetch (pas de <form action>) pour éviter les rechargements
 * - État "loading" sur le bouton pendant la requête
 * - Affichage des erreurs inline
 */

export const prerender = false;

import Layout from '../layouts/Layout.astro';
import { auth } from '../lib/auth';

// ── Vérification session côté serveur ─────────────────────────────────────
const session = await auth.api.getSession({
  headers: Astro.request.headers,
});

// Si l'utilisateur est déjà connecté, rediriger vers l'espace admin
if (session) {
  return Astro.redirect('/mes-rdvs/');
}
---

<Layout
  title="Connexion — OMF Thérapie"
  description="Connexion à l'espace praticienne d'OMF Thérapie."
  noindex={true}
>
  <main class="min-h-screen bg-sage-50 flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-md">

      <!-- En-tête -->
      <div class="text-center mb-10">
        <a href="/" class="inline-block mb-6" aria-label="Retour à l'accueil">
          <span class="font-serif text-2xl font-semibold text-sage-800 tracking-wide">
            OMF Thérapie
          </span>
        </a>
        <h1 class="font-serif text-3xl font-semibold text-sage-800 mb-2">
          Espace praticienne
        </h1>
        <p class="text-sage-500 text-sm font-sans">
          Connectez-vous pour gérer vos rendez-vous
        </p>
      </div>

      <!-- Carte formulaire -->
      <div class="bg-white rounded-2xl shadow-sm border border-sage-100 px-8 py-10">

        <!-- Zone d'erreur (cachée par défaut) -->
        <div
          id="error-msg"
          role="alert"
          aria-live="polite"
          class="hidden mb-6 flex items-start gap-3 bg-red-50 border border-red-200 text-red-700 rounded-xl px-4 py-3 text-sm font-sans"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5 flex-shrink-0 mt-0.5 text-red-500"
            viewBox="0 0 20 20"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z"
              clip-rule="evenodd"
            />
          </svg>
          <span id="error-text">Une erreur est survenue.</span>
        </div>

        <!-- Formulaire -->
        <form id="login-form" novalidate class="space-y-5">

          <!-- Email -->
          <div>
            <label
              for="email"
              class="block text-sm font-medium text-sage-700 font-sans mb-1.5"
            >
              Adresse e-mail
            </label>
            <input
              type="email"
              id="email"
              name="email"
              autocomplete="email"
              required
              placeholder="votre@email.fr"
              class="
                w-full px-4 py-2.5 rounded-xl border border-sage-200 bg-sage-50
                text-sage-900 placeholder-sage-400 font-sans text-sm
                focus:outline-none focus:ring-2 focus:ring-mint-400 focus:border-transparent
                transition-colors duration-200
                disabled:opacity-50 disabled:cursor-not-allowed
              "
            />
          </div>

          <!-- Mot de passe -->
          <div>
            <label
              for="password"
              class="block text-sm font-medium text-sage-700 font-sans mb-1.5"
            >
              Mot de passe
            </label>
            <input
              type="password"
              id="password"
              name="password"
              autocomplete="current-password"
              required
              placeholder="••••••••"
              class="
                w-full px-4 py-2.5 rounded-xl border border-sage-200 bg-sage-50
                text-sage-900 placeholder-sage-400 font-sans text-sm
                focus:outline-none focus:ring-2 focus:ring-mint-400 focus:border-transparent
                transition-colors duration-200
                disabled:opacity-50 disabled:cursor-not-allowed
              "
            />
          </div>

          <!-- Bouton de connexion -->
          <button
            id="submit-btn"
            type="submit"
            class="
              w-full mt-2 px-6 py-3 rounded-xl font-sans font-medium text-sm
              bg-mint-600 text-white
              hover:bg-mint-700 active:bg-mint-800
              focus:outline-none focus:ring-2 focus:ring-mint-400 focus:ring-offset-2
              transition-all duration-200
              disabled:opacity-60 disabled:cursor-not-allowed
              flex items-center justify-center gap-2 min-h-[44px]
            "
          >
            <!-- Icône loading (cachée par défaut) -->
            <svg
              id="loading-spinner"
              class="hidden h-4 w-4 animate-spin text-white"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <circle
                class="opacity-25"
                cx="12" cy="12" r="10"
                stroke="currentColor"
                stroke-width="4"
              ></circle>
              <path
                class="opacity-75"
                fill="currentColor"
                d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"
              ></path>
            </svg>
            <span id="btn-label">Se connecter</span>
          </button>

        </form>
      </div>

      <!-- Retour au site -->
      <p class="text-center mt-6 text-sm text-sage-400 font-sans">
        <a
          href="/"
          class="hover:text-sage-600 transition-colors duration-200 underline underline-offset-2"
        >
          ← Retour au site
        </a>
      </p>

    </div>
  </main>
</Layout>

<script>
  /**
   * Gestion de la soumission du formulaire de connexion.
   *
   * - Soumet les identifiants via fetch POST vers /api/auth/sign-in/email
   * - BetterAuth v1.x définit le cookie de session dans la réponse HTTP
   * - En cas de succès → redirection vers /mes-rdvs
   * - En cas d'erreur → affichage du message dans #error-msg
   */

  const form = document.getElementById('login-form') as HTMLFormElement | null;
  const emailInput = document.getElementById('email') as HTMLInputElement | null;
  const passwordInput = document.getElementById('password') as HTMLInputElement | null;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const loadingSpinner = document.getElementById('loading-spinner') as SVGElement | null;
  const btnLabel = document.getElementById('btn-label') as HTMLSpanElement | null;
  const errorMsg = document.getElementById('error-msg') as HTMLDivElement | null;
  const errorText = document.getElementById('error-text') as HTMLSpanElement | null;

  /** Affiche le message d'erreur dans la zone dédiée */
  function showError(message: string): void {
    if (!errorMsg || !errorText) return;
    errorText.textContent = message;
    errorMsg.classList.remove('hidden');
    errorMsg.classList.add('flex');
    // Focus sur la zone d'erreur pour l'accessibilité
    errorMsg.focus();
  }

  /** Cache la zone d'erreur */
  function hideError(): void {
    if (!errorMsg) return;
    errorMsg.classList.add('hidden');
    errorMsg.classList.remove('flex');
  }

  /** Active/désactive l'état loading du bouton */
  function setLoading(loading: boolean): void {
    if (!submitBtn || !loadingSpinner || !btnLabel || !emailInput || !passwordInput) return;

    submitBtn.disabled = loading;
    emailInput.disabled = loading;
    passwordInput.disabled = loading;

    if (loading) {
      loadingSpinner.classList.remove('hidden');
      btnLabel.textContent = 'Connexion…';
    } else {
      loadingSpinner.classList.add('hidden');
      btnLabel.textContent = 'Se connecter';
    }
  }

  form?.addEventListener('submit', async (event: SubmitEvent) => {
    event.preventDefault();
    hideError();

    const email = emailInput?.value?.trim() ?? '';
    const password = passwordInput?.value ?? '';

    // Validation minimale côté client
    if (!email || !password) {
      showError('Veuillez renseigner votre e-mail et votre mot de passe.');
      return;
    }

    setLoading(true);

    try {
      // BetterAuth v1.x endpoint : POST /api/auth/sign-in/email/
      const response = await fetch('/api/auth/sign-in/email/', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Origin': window.location.origin,
        },
        // Inclure les cookies dans la requête (nécessaire pour la gestion de session)
        credentials: 'same-origin',
        body: JSON.stringify({ email, password }),
      });

      if (response.ok) {
        // Connexion réussie — BetterAuth a défini le cookie de session
        window.localStorage.setItem('omf-admin-auth', '1');
        window.location.href = '/mes-rdvs/';
        return;
      }

      // Gestion des erreurs HTTP
      let errorMessage = 'Identifiants incorrects. Veuillez réessayer.';

      try {
        const data = await response.json() as { error?: string; message?: string };
        if (data?.error) {
          errorMessage = data.error;
        } else if (data?.message) {
          errorMessage = data.message;
        }
      } catch {
        // La réponse n'est pas du JSON — garder le message par défaut
      }

      // Cas spécifiques selon le statut HTTP
      if (response.status === 401 || response.status === 400) {
        errorMessage = 'E-mail ou mot de passe incorrect.';
      } else if (response.status === 429) {
        errorMessage = 'Trop de tentatives. Veuillez patienter quelques minutes.';
      } else if (response.status >= 500) {
        errorMessage = 'Erreur serveur. Veuillez réessayer dans quelques instants.';
      }

      showError(errorMessage);
    } catch (networkError) {
      // Erreur réseau (hors ligne, timeout, etc.)
      console.error('[login] Erreur réseau :', networkError);
      showError('Impossible de se connecter. Vérifiez votre connexion internet.');
    } finally {
      setLoading(false);
    }
  });
</script>
