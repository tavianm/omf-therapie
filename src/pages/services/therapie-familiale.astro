---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/islands/Navbar';
import Footer from '../../components/layout/Footer.astro';
import { buildFAQSchema, buildServiceSchema } from '../../utils/schema';

const faqs = [
  {
    question: "À quoi sert une thérapie familiale ?",
    answer: "La thérapie familiale améliore la communication et les dynamiques au sein de la famille. Elle permet de mettre des mots sur les tensions, de mieux comprendre les besoins de chacun et de trouver ensemble des modes de fonctionnement plus apaisés et respectueux.",
  },
  {
    question: "Qui doit être présent en thérapie familiale ?",
    answer: "Il n'est pas obligatoire que tous les membres de la famille soient présents à chaque séance. La thérapie s'adapte à ceux qui souhaitent s'impliquer dans la démarche. L'essentiel est la volonté de travailler ensemble sur les dynamiques relationnelles.",
  },
  {
    question: "La thérapie familiale convient-elle aux adolescents ?",
    answer: "Oui, la thérapie familiale est souvent le cadre idéal pour les adolescents en difficulté relationnelle avec leurs parents. Elle offre un espace sécurisé où chacun peut s'exprimer, être entendu et comprendre le point de vue de l'autre, sans que les tensions habituelles n'entravent le dialogue.",
  },
  {
    question: "Combien de séances pour une thérapie familiale à Montpellier ?",
    answer: "Le nombre de séances est variable selon la complexité de la situation familiale. En général, un suivi de 5 à 15 séances est engagé, avec une réévaluation régulière des objectifs et des progrès en accord avec la famille.",
  },
];

const jsonLd = [
  buildFAQSchema(faqs),
  buildServiceSchema(
    "Thérapie familiale à Montpellier",
    "Accompagnement des conflits intergénérationnels, adolescents en difficulté et recompositions familiales par Oriane Montabonnet, psychopraticienne à Montpellier.",
    "https://omf-therapie.fr/services/therapie-familiale"
  ),
];
---

<Layout
  title="Thérapie familiale à Montpellier | Oriane Montabonnet — Psychopraticienne"
  description="Thérapie familiale à Montpellier avec Oriane Montabonnet. Accompagnement des conflits intergénérationnels, adolescents en difficulté, recomposition familiale."
  canonical="https://omf-therapie.fr/services/therapie-familiale"
  jsonLd={jsonLd}
>
  <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-mint-600 focus:text-white focus:rounded">
    Aller au contenu principal
  </a>

  <Navbar client:load />

  <main id="main-content" class="pt-20" tabindex="-1">
    <section class="bg-sage-50 py-12 px-4">
      <div class="max-w-4xl mx-auto">
        <nav class="mb-6 text-sm text-sage-500" aria-label="Fil d'Ariane">
          <ol class="flex items-center gap-2 flex-wrap" role="list">
            <li role="listitem"><a href="/" class="hover:text-mint-600 transition-colors">Accueil</a></li>
            <li role="listitem" aria-hidden="true">›</li>
            <li role="listitem"><a href="/#services" class="hover:text-mint-600 transition-colors">Services</a></li>
            <li role="listitem" aria-hidden="true">›</li>
            <li role="listitem" aria-current="page" class="text-sage-700 font-medium">Thérapie familiale</li>
          </ol>
        </nav>
        <h1 class="font-serif text-3xl md:text-4xl lg:text-5xl text-sage-800 mb-6">Thérapie familiale à Montpellier</h1>
        <p class="text-xl text-sage-600 max-w-3xl leading-relaxed">La thérapie familiale avec Oriane Montabonnet, psychopraticienne à Montpellier, offre un espace de dialogue pour les familles traversant des tensions, des conflits intergénérationnels ou des transitions difficiles. L'objectif : restaurer la communication et retrouver un équilibre familial apaisé.</p>
        <div class="mt-6">
          <a href="/contact" class="inline-flex items-center gap-2 bg-mint-600 text-white px-6 py-3 rounded-lg hover:bg-mint-700 transition-colors font-medium">
            Prendre rendez-vous
          </a>
        </div>
      </div>
    </section>

    <section class="max-w-4xl mx-auto px-4 py-12 space-y-10">
      <div>
        <h2 class="font-serif text-2xl text-sage-800 mb-4">Pour qui est la thérapie familiale ?</h2>
        <p class="text-sage-600 leading-relaxed">La thérapie familiale s'adresse à toutes les configurations familiales confrontées à des difficultés relationnelles ou à des changements importants.</p>
        <ul class="mt-4 space-y-2 text-sage-600" aria-label="Situations concernées par la thérapie familiale">
          <li class="flex items-start gap-2"><span class="text-mint-600 mt-1" aria-hidden="true">•</span>Familles avec tensions répétitives ou conflits durables</li>
          <li class="flex items-start gap-2"><span class="text-mint-600 mt-1" aria-hidden="true">•</span>Adolescents en difficulté ou en opposition avec les parents</li>
          <li class="flex items-start gap-2"><span class="text-mint-600 mt-1" aria-hidden="true">•</span>Familles traversant un divorce ou une séparation</li>
          <li class="flex items-start gap-2"><span class="text-mint-600 mt-1" aria-hidden="true">•</span>Familles recomposées en phase d'adaptation</li>
          <li class="flex items-start gap-2"><span class="text-mint-600 mt-1" aria-hidden="true">•</span>Deuil familial ou traumatisme partagé</li>
          <li class="flex items-start gap-2"><span class="text-mint-600 mt-1" aria-hidden="true">•</span>Conflits intergénérationnels entre parents et enfants adultes</li>
        </ul>
      </div>

      <div>
        <h2 class="font-serif text-2xl text-sage-800 mb-4">Comment fonctionne la thérapie familiale ?</h2>
        <p class="text-sage-600 leading-relaxed">La thérapie familiale réunit plusieurs membres de la famille dans un même espace thérapeutique. Oriane Montabonnet travaille sur les dynamiques relationnelles : les schémas de communication, les rôles implicites et les besoins non exprimés de chacun. En identifiant les patterns qui génèrent de la souffrance, la thérapie permet à la famille de construire de nouvelles façons d'interagir, fondées sur l'écoute et le respect mutuel.</p>
      </div>

      <div>
        <h2 class="font-serif text-2xl text-sage-800 mb-4">Questions fréquentes sur la thérapie familiale à Montpellier</h2>
        <div class="space-y-6" itemscope itemtype="https://schema.org/FAQPage">
          {faqs.map((faq) => (
            <div class="border-l-4 border-mint-200 pl-4" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
              <h3 class="font-semibold text-sage-800 mb-2" itemprop="name">{faq.question}</h3>
              <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
                <p class="text-sage-600" itemprop="text">{faq.answer}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
