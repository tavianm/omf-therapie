---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import { ArrowLeft, Calendar, Clock, Tag, User } from 'lucide-react';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/islands/Navbar';
import Footer from '../../components/layout/Footer.astro';
import { ShareButtons } from '../../components/blog/ShareButtons';
import { collectionEntryToBlogPost } from '../../utils/blogAdapter';
import { buildArticleSchema } from '../../utils/schema';
import { calculateReadingTime } from '../../utils/readingTime';

export const getStaticPaths: GetStaticPaths = async () => {
  const entries = await getCollection('blog');
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.md$/, '') }, // strip .md extension from Astro 5 entry.id
    props: { entry },
  }));
};

const { entry } = Astro.props;
const { Content } = await entry.render();
const post = collectionEntryToBlogPost(entry);

// Get related posts (same category, exclude current, not disabled)
const allEntries = await getCollection('blog');
const allPosts = allEntries.map(collectionEntryToBlogPost);
const relatedPosts = allPosts
  .filter(
    (p) =>
      p.slug !== post.slug &&
      !p.disabled &&
      p.categories.some((cat) => post.categories.includes(cat))
  )
  .slice(0, 2);

const jsonLd = buildArticleSchema(post);
const canonicalUrl = `https://omf-therapie.fr/blog/${post.slug}`;
const readingTime = calculateReadingTime(entry.body ?? '');
---

<Layout
  title={`${post.title} | Blog — Oriane Montabonnet`}
  description={post.excerpt}
  canonical={canonicalUrl}
  ogType="article"
  ogImage={post.imageUrl}
  jsonLd={jsonLd}
>
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-mint-600 focus:text-white focus:rounded"
  >
    Aller au contenu principal
  </a>

  <Navbar client:load />

  <main id="main-content" class="pt-20" tabindex="-1">
    <div class="max-w-4xl mx-auto px-4 py-12">
      <a href="/blog" class="inline-flex items-center text-mint-600 hover:text-mint-700 mb-6">
        <ArrowLeft className="h-4 w-4 mr-2" />
        Retour aux articles
      </a>

      <article class="bg-white rounded-lg shadow-sm overflow-hidden p-6 md:p-8">
        <div class="flex flex-wrap gap-2 mb-4">
          {post.categories.map((category) => (
            <a
              href={`/blog?category=${encodeURIComponent(category)}`}
              class="inline-flex items-center gap-1 text-xs font-medium text-mint-600 bg-mint-50 px-2 py-1 rounded-full hover:bg-mint-100 transition-colors"
            >
              <Tag className="h-3 w-3" />
              {category}
            </a>
          ))}
        </div>

        <h1 class="text-3xl md:text-4xl font-serif font-semibold text-sage-800 mb-4">
          {post.title}
        </h1>

        <div class="flex flex-wrap items-center text-sage-500 text-sm mb-6">
          <span class="flex items-center mr-4 mb-2">
            <User className="h-4 w-4 mr-1" />
            Oriane Montabonnet
          </span>
          <span class="flex items-center mr-4 mb-2">
            <Calendar className="h-4 w-4 mr-1" />
            {post.date}
          </span>
          <span class="flex items-center mb-2">
            <Clock className="h-4 w-4 mr-1" />
            {readingTime} min de lecture
          </span>
        </div>

        {post.imageUrl && (
          <div class="mb-6">
            <img
              src={post.imageUrl}
              alt={post.title}
              class="h-auto rounded-lg"
              loading="lazy"
              decoding="async"
              width="800"
              height="400"
            />
          </div>
        )}

        <div class="prose prose-sage max-w-none mb-8">
          <Content />
        </div>

        <div class="border-t border-sage-100 pt-6 flex flex-wrap justify-between items-center">
          <div class="mb-4 md:mb-0">
            <h3 class="text-sage-700 font-medium mb-2">Partager cet article</h3>
            <ShareButtons post={post} client:visible />
          </div>
          <a href="/contact" class="text-mint-600 font-medium hover:text-mint-700 transition-colors">
            Des questions ? Contactez-moi
          </a>
        </div>
      </article>

      {relatedPosts.length > 0 && (
        <div class="mt-12">
          <h2 class="text-2xl font-serif font-semibold text-sage-800 mb-6">
            Articles similaires
          </h2>
          <div class="grid md:grid-cols-2 gap-6">
            {relatedPosts.map((relatedPost) => (
              <div class="bg-white rounded-lg shadow-sm overflow-hidden">
                <a href={`/blog/${relatedPost.slug}`} class="block p-6">
                  <div class="flex flex-wrap gap-2 mb-2">
                    {relatedPost.categories.slice(0, 1).map((category) => (
                      <span class="inline-flex items-center gap-1 text-xs font-medium text-mint-600 bg-mint-50 px-2 py-1 rounded-full">
                        {category}
                      </span>
                    ))}
                  </div>
                  <h3 class="text-xl font-serif font-semibold text-sage-800 mb-2 hover:text-mint-600 transition-colors">
                    {relatedPost.title}
                  </h3>
                  <p class="text-sage-600 line-clamp-2">{relatedPost.excerpt}</p>
                </a>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </main>

  <Footer />
</Layout>
