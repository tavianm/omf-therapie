# =============================================================================
# Variables d'environnement — OMF Thérapie
# Copier ce fichier en .env et renseigner les valeurs
# NE JAMAIS committer .env — voir .gitignore
# =============================================================================

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_DATABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=<votre-clé-anon>
SUPABASE_SERVICE_ROLE_KEY=<votre-clé-service-role-CONFIDENTIELLE>

# ── BetterAuth ────────────────────────────────────────────────────────────────
# Connexion PostgreSQL Supabase (BetterAuth + pg.Pool)
# Pooler (recommandé en serverless) : postgres://postgres.[ref]:[password]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres
# Direct (alternative)              : postgresql://postgres:[password]@db.<ref>.supabase.co:5432/postgres
DATABASE_URL=postgres://postgres.[ref]:[password]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres
# Certificat racine Supabase (PEM multiline, coller tel quel) pour la vérification TLS.
# À récupérer sur Supabase Dashboard → Database → Connection string → SSL / "Root certificate".
# Requis en production (Netlify dashboard, scope prod + deploy-preview). Optionnel en local.
SUPABASE_CA_CERT=
# Générer avec : openssl rand -base64 32
BETTER_AUTH_SECRET=<secret-aléatoire-min-32-chars>
BETTER_AUTH_URL=https://omf-therapie.fr

# ── Email admin ───────────────────────────────────────────────────────────────
ADMIN_EMAIL=contact@omf-therapie.fr
# Minimum 16 caractères, mixte majuscules/minuscules/chiffres/symboles
ADMIN_PASSWORD=<mot-de-passe-fort-16-chars-min>

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_<votre-clé>
STRIPE_PUBLISHABLE_KEY=pk_live_<votre-clé>
STRIPE_WEBHOOK_SECRET=whsec_<votre-secret>
# URL de redirection après paiement réussi
STRIPE_SUCCESS_URL=https://omf-therapie.fr/rdv/merci

# ── Resend ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_<votre-clé>
RESEND_FROM_EMAIL=OMF Thérapie <contact@omf-therapie.fr>

# ── Google Calendar ───────────────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=<email>@<project>.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
GOOGLE_CALENDAR_ID=<calendar-id>@group.calendar.google.com
# OAuth utilisateur (3-legged) pour génération Google Meet sur compte perso
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_OAUTH_REDIRECT_URI=https://developers.google.com/oauthplayground

# ── Avis (optionnels) ─────────────────────────────────────────────────────────
GOOGLE_BUSINESS_URL=
PAGES_JAUNES_URL=
PSYCHOLOGUE_NET_URL=

# ── Piwik PRO (analytics côté client) ────────────────────────────────────────
VITE_PIWIK_CONTAINER_ID=<container-id>
VITE_PIWIK_CONTAINER_URL=https://<workspace>.piwik.pro
ENABLE_LSP_TOOL=1

# ── Sentry (observabilité — error tracking + structured logging) ─────────────
# DSN public (clé publique — safe to expose côté client). Préfixe PUBLIC_
# requis pour qu'Astro l'expose au navigateur (mirroir de PUBLIC_GA4_ID).
# Format: https://<key>@o<orgId>.ingest.us.sentry.io/<projectId>
# Optionnel : si vide, le SDK reste inert et le logger dégrade vers console.*
PUBLIC_SENTRY_DSN=
